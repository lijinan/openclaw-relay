{
  "server": {
    "url": "wss://your-server.com/relay/ws",
    "reconnectInterval": 5000,
    "maxReconnectAttempts": 0
  },
  "auth": {
    "clientId": "openclaw-local",
    "authToken": "your-auth-token-here"
  },
  "openclaw": {
    "baseUrl": "http://localhost:18789",
    "webhookPath": "/webhooks/wecom",
    "timeout": 60000
  },
  "heartbeat": {
    "interval": 30000,
    "timeout": 10000
  }
}
