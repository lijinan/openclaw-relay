{
  "server": {
    "url": "wss://your-server.com/relay/ws",
    "reconnectInterval": 5000,
    "maxReconnectAttempts": 0
  },
  "auth": {
    "clientId": "relay-local",
    "authToken": "your-auth-token-here"
  },
  "destination": {
    "baseUrl": "http://localhost:3000",
    "timeout": 60000,
    "allowedPages": [
      "/webhooks/wecom",
      "/api/*"
    ]
  },
  "heartbeat": {
    "interval": 30000,
    "timeout": 10000
  }
}
